<Window x:Class="AstroDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AstroDashboard"
        mc:Ignorable="d"
        Title="Astrophotography Dashboard" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:NodeTypeColorConverter x:Key="NodeTypeColorConverter"/>
        <local:NodeTypeToFontWeightConverter x:Key="NodeTypeToFontWeightConverter"/>
        <local:DepthToNumericColumnMarginConverter x:Key="DepthToNumericColumnMarginConverter"/>
    </Window.Resources>
    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Background="White">
            <Button Command="{Binding BrowseCommand}" Padding="10,5" Margin="0,0,5,0" Background="#0078D4" Foreground="White" FontWeight="Bold">
                Browse...
            </Button>
            <TextBox Text="{Binding SelectedPath, Mode=TwoWay}" Padding="5" Width="300" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button Command="{Binding RefreshCommand}" Padding="10,5" Margin="0,0,10,0" Background="#0078D4" Foreground="White" FontWeight="Bold">
                Refresh
            </Button>
        </StackPanel>

        <!-- Main Content -->
        <Border Grid.Row="1" Margin="10" Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
            <Grid TextElement.FontSize="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Projects Summary" Padding="10" FontWeight="Bold" Background="#E8E8E8"/>

                <Grid Grid.Row="1" Background="#F7F7F7" Margin="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="520"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" Padding="10,6"/>
                    <TextBlock Grid.Column="1" Text="Files" FontWeight="SemiBold" Padding="10,6" TextAlignment="Right"/>
                    <TextBlock Grid.Column="2" Text="Minutes" FontWeight="SemiBold" Padding="10,6" TextAlignment="Right"/>
                </Grid>

                <TreeView Grid.Row="2" ItemsSource="{Binding TreeNodes}" Padding="4">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Grid Margin="0,1" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="520"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="0,2,8,2" Foreground="{Binding NodeType, Converter={StaticResource NodeTypeColorConverter}}" FontWeight="{Binding NodeType, Converter={StaticResource NodeTypeToFontWeightConverter}}"/>
                                <TextBlock Grid.Column="1" Text="{Binding FileCountText}" Margin="{Binding Depth, Converter={StaticResource DepthToNumericColumnMarginConverter}}" TextAlignment="Right" FontWeight="{Binding NodeType, Converter={StaticResource NodeTypeToFontWeightConverter}}"/>
                                <TextBlock Grid.Column="2" Text="{Binding MinutesText}" Margin="{Binding Depth, Converter={StaticResource DepthToNumericColumnMarginConverter}}" TextAlignment="Right" FontWeight="{Binding NodeType, Converter={StaticResource NodeTypeToFontWeightConverter}}"/>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Margin="5"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
